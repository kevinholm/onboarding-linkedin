{
  "manifest_version": 3,
  "name": "LinkedIn Executive Copilot",
  "version": "1.0.0",
  "description": "AI-powered Thought Leadership assistant for LinkedIn Executives.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Executive Copilot"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
